# Ghostberry environment configuration
# Copy to .env and fill in. NEVER commit .env.
# `setup.sh` (or the one-shot installer) will write this for you.

# ---------------- Ghost ----------------
# Public URL of your Ghost blog (must include https://)
GHOST_URL=https://blog.example.com

# ---------------- Database -------------
# Generated by setup.sh; only set manually if you know what you're doing.
GHOST_DB_PASSWORD=
MYSQL_ROOT_PASSWORD=

# ---------------- Cloudflare Tunnel ----
# Create in https://one.dash.cloudflare.com/ → Networks → Tunnels.
# Configure a public hostname pointing to: http://ghost:2368
CLOUDFLARE_TUNNEL_TOKEN=

# ---------------- Mail (optional) ------
# Leave blank to disable. Generic SMTP — works with Mailgun, SendGrid,
# Postmark, Fastmail, Gmail (app passwords), Brevo, etc.
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SECURE=false

# ---------------- Backups --------------
# AES-256 passphrase for encrypted backups. Auto-generated by setup.sh.
# Without this, backups are stored unencrypted (still chmod 600).
BACKUP_ENCRYPTION_KEY=
# Number of backup archives to keep.
BACKUP_KEEP=7

# ---------------- Image pins -----------
# Override to pin specific versions. Defaults track the maintained tags.
GHOST_IMAGE=ghost:5-alpine
MYSQL_IMAGE=mysql:8.0
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest

# ---------------- Resource caps --------
# Tune for your Pi. Defaults target a 2 GB Pi 4.
GHOST_MEM_LIMIT=768m
DB_MEM_LIMIT=512m
CLOUDFLARED_MEM_LIMIT=128m
MYSQL_BUFFER_POOL=128M
