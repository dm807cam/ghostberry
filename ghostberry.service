[Unit]
Description=Ghostberry — Ghost CMS + Cloudflare Tunnel
Documentation=https://github.com/dm807cam/ghostberry
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/ghostberry
# Compose reads .env from WorkingDirectory directly; we deliberately do NOT
# use EnvironmentFile= here because systemd's dotenv parser interprets
# quotes/backslashes differently from compose's, and the file is the
# canonical source — duplicating it through systemd just risks drift.
ExecStart=/usr/bin/docker compose up -d --remove-orphans
ExecStop=/usr/bin/docker compose down
TimeoutStartSec=300
Restart=on-failure
RestartSec=30

[Install]
WantedBy=multi-user.target
